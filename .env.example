# Optional configuration. Most paths use containerlab defaults.
# Copy to .env (gitignored) if any overrides are needed.

# Path to private SSH key for connecting to Cumulus VX nodes.
# containerlab generates and distributes a per-topology key by default;
# override only if you've configured a custom key in the topology file.
# CONTAINERLAB_SSH_KEY_PATH=

# Cumulus VX image to use (default: networkop/cx:5.0).
# CUMULUS_VX_IMAGE=networkop/cx:5.0
